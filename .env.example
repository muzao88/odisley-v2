# Variáveis de Ambiente - Exemplo
# Copie este arquivo para .env.local e preencha os valores reais

# ========== ADMIN ==========
# Nome de usuário do admin
ADMIN_USER=admin

# Hash bcrypt da senha do admin (gere com: npx bcryptjs-cli hash sua_senha)
# Exemplo de hash: $2a$10$abcdef123456789...
ADMIN_PASS_HASH=$2a$10$YourBcryptHashHere

# ========== JWT ==========
# Chave secreta para assinar JWTs (use uma string aleatória forte)
# Exemplo: openssl rand -base64 32
JWT_SECRET=sua_chave_secreta_muito_segura_aqui

# ========== DATABASE ==========
MONGODB_URI=mongodb+srv://usuario:senha@cluster.mongodb.net/odisley

# ========== GOOGLE OAUTH ==========
GOOGLE_CLIENT_ID=seu_google_client_id
GOOGLE_CLIENT_SECRET=seu_google_client_secret

# ========== STRIPE ==========
STRIPE_SECRET_KEY=sk_test_seu_stripe_key
STRIPE_PUBLISHABLE_KEY=pk_test_seu_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_seu_webhook_secret

# ========== KIWIFY ==========
KIWIFY_API_TOKEN=seu_kiwify_api_token
