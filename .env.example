# ── Banco de dados ────────────────────────────────────────────
# Crie grátis em mongodb.com/atlas
MONGODB_URI=mongodb+srv://usuario:senha@cluster.mongodb.net/odisley

# ── Autenticação JWT ──────────────────────────────────────────
# Qualquer frase longa e aleatória
JWT_SECRET=odisley-matematica-enem-2025-coloque-algo-aqui

# ── URL do site ───────────────────────────────────────────────
NEXT_PUBLIC_URL=http://localhost:3000

# ── Google OAuth ──────────────────────────────────────────────
# Crie em console.cloud.google.com → APIs → Credenciais → ID do cliente OAuth 2.0
# Tipo: Aplicativo da Web
# Origens permitidas: http://localhost:3000 (dev) e https://seusite.vercel.app (prod)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=523092291502-mvrc0eqfj5egggpk5ol5ho0fue4bvt6ei.apps.googleusercontent.com

# ── Stripe (pagamentos internacionais — cartão) ───────────────
# Crie em dashboard.stripe.com
# Use as chaves "test" para desenvolvimento e "live" para produção
STRIPE_SECRET_KEY=sk_test_XXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXX
STRIPE_PRICE_MENSAL=price_XXXXX
STRIPE_PRICE_ANUAL=price_XXXXX

# ── MercadoPago (Brasil — Pix, Boleto, Cartão) ────────────────
# Crie em mercadopago.com.br → Suas integrações → Credenciais
MERCADOPAGO_ACCESS_TOKEN=APP_USR-XXXXX
